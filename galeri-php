            // Folder tempat gambar disimpan
            $folder = 'galeri-job/';
            
            // Check kalau folder tu wujud
            if (is_dir($folder)) {
                // Tarik semua fail gambar (jpg, jpeg, png)
                $gambar = glob($folder . "*.{jpg,jpeg,png}", GLOB_BRACE);
                
                if (count($gambar) > 0) {
                    // Susun gambar ikut tarikh paling baru (newest first)
                    usort($gambar, function($a, $b) {
                        return filemtime($b) - filemtime($a);
                    });

                    // Loop dan keluarkan setiap gambar
                    foreach ($gambar as $imej) {
                        // Ambil nama fail tanpa folder untuk dijadikan caption
                        $nama_fail = basename($imej);
                        
                        // Bersihkan nama untuk nampak cantik kat caption (buang extension dan nombor hujung)
                        // Contoh: majlis-tunang-masai-20260708-001.jpg jadi "Majlis Tunang Masai"
                        $caption_raw = preg_replace('/-\d{8}-\d{3}\.jpg$/i', '', $nama_fail);
                        $caption_bersih = str_replace('-', ' ', $caption_raw);

                        echo '<div class="gallery-item">';
                        // Guna lazy loading supaya page laju
                        echo '<img src="' . $imej . '" alt="' . htmlspecialchars($caption_bersih) . '" loading="lazy">';
                        echo '<div class="caption">' . htmlspecialchars($caption_bersih) . '</div>';
                        echo '</div>';
                    }
                } else {
                    echo '<div class="no-data">Belum ada gambar job di-upload lagi.</div>';
                }
            } else {
                echo '<div class="no-data">Sistem sedang dikemaskini.</div>';
            }
            ?>
        </div>
    </div>

