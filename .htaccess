# Halang Apache dari teka fail dan halang orang selongkar folder assets
Options -MultiViews -Indexes

RewriteEngine On

# 1. PAKSA PENGGUNAAN HTTPS (Sangat penting untuk Google SEO & Security)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. OLD .html URL redirects to current folder URLs
Redirect 301 /sewa-aircooler-kulai.html /sewa-aircooler-kulai/
Redirect 301 /sewa-aircooler-skudai.html /sewa-aircooler-skudai/
Redirect 301 /sewa-aircooler-johor-bahru.html /sewa-aircooler-johor-bahru/
Redirect 301 /sewa-aircooler-iskandar-puteri.html /sewa-aircooler-iskandar-puteri/
Redirect 301 /sewa-aircooler-pasir-gudang.html /sewa-aircooler-pasir-gudang/
Redirect 301 /sewa-aircooler-senai.html /sewa-aircooler-senai/

# 3. Force trailing slash for folder-style URLs (Kekalkan, untuk elak path gambar rosak)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+)$ /$1/ [R=301,L]

# 4. Serve index.html inside folder
DirectoryIndex index.html
